# Choose one provider and set its key. LLM_PROVIDER controls which client
# app/agent/llm_client.py uses.
LLM_PROVIDER=anthropic          # anthropic | openai
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Model names
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o-mini

# Confidence threshold below which the agent escalates instead of proposing a fix
CONFIDENCE_THRESHOLD=0.6

CHROMA_HOST=localhost
CHROMA_PORT=8001
